<launch>
  <arg name="sensorPitch" default="0"/>
  <arg name="vehicleX" default="0"/>
  <arg name="vehicleY" default="0"/>
  <arg name="vehicleZ" default="1.0"/>
  <arg name="vehicleYaw" default="0"/>
  <arg name="paused" default="false"/>
  <arg name="use_sim_time" default="true"/>
  <arg name="realtime_factor" default="1.0"/>
  <arg name="gui" default="false"/>
  <arg name="headless" default="false"/>
  <arg name="debug" default="false"/>
  <arg name="verbose" default="false"/>
  <arg name="world_name" default="forest"/>
  <arg name="use_gazebo" default="true"/>
  <arg name="robotModelName" default="robot"/>
  <arg name="uav_lidar_model_name" default="uav_lidar"/>
  <arg name="rgbdCameraModelName" default="rgbd_camera"/>
  
  <group if="$(arg use_gazebo)">
    <include file="$(find gazebo_ros)/launch/empty_world.launch" >
      <arg name="paused" value="$(arg paused)"/>
      <arg name="use_sim_time" value="$(arg use_sim_time)"/>
      <arg name="gui" value="$(arg gui)"/>
      <arg name="headless" value="$(arg headless)"/>
      <arg name="debug" value="$(arg debug)"/>
      <arg name="verbose" value="$(arg verbose)"/>
      <arg name="world_name" value="$(find vehicle_simulator_uav)/world/$(arg world_name).world"/>
    </include>

    <param name="rgbd_camera_description" command="$(find xacro)/xacro --inorder '$(find vehicle_simulator_uav)/urdf/rgbd_camera.urdf.xacro'" />
    <node pkg="gazebo_ros" type="spawn_model" name="spawn_rgbd_camera" args="-urdf -param /rgbd_camera_description -model $(arg rgbdCameraModelName)"/>
    
    <param name="robot_description" command="$(find xacro)/xacro --inorder '$(find vehicle_simulator_uav)/urdf/robot.urdf.xacro'" />
    <node pkg="gazebo_ros" type="spawn_model" name="spawn_robot" args="-urdf -param /robot_description -model $(arg robotModelName)"/>
  </group>
    <param name="windCoeff" type="double" value="0.05" />

  <node pkg="vehicle_simulator_uav" type="vehicleSimulator_uav" name="vehicleSimulator" output="screen">
    <param name="realtimeFactor" value="$(arg realtime_factor)" />
    <param name="maxRollPitchRate" type="double" value="20.0" />
    <param name="rollPitchSmoothRate" type="double" value="0.1" />
    <param name="sensorPitch" value="$(arg sensorPitch)" />
    <param name="vehicleX" value="$(arg vehicleX)" />
    <param name="vehicleY" value="$(arg vehicleY)" />
    <param name="vehicleZ" value="$(arg vehicleZ)" />
    <param name="vehicleYaw" value="$(arg vehicleYaw)" />
    <param name="lidarModelName" value="$(arg uav_lidar_model_name)" />
    <param name="robotModelName" value="$(arg robotModelName)" />
    <param name="rgbdCameraModelName" value="$(arg rgbdCameraModelName)" />
  </node>

</launch>
