<launch>
    <arg name="bag_path" default="Desktop"/>
    <arg name="bag_name_prefix" default="exploration"/>
    <node pkg="rosbag" type="record" name="rosbag_record_tare_planner"
          args="record -o $(env HOME)/$(arg bag_path)/$(arg bag_name_prefix) -e '/ugv/sensor_coverage_planner/(.*)' /tf /ugv/registered_scan /ugv/state_estimation /ugv/state_estimation_at_scan /velodyne_cloud_registered /integrated_to_init /aft_mapped_to_init /ugv/way_point /ugv/runtime"/>
</launch>
